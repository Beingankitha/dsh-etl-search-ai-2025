# Application Configuration
APP_NAME="CEH Dataset Discovery"
APP_ENV=development
DEBUG=true

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration (Issue #5)
DATABASE_PATH=./data/datasets.db # data/dsh_etl.sqlite #
SUPPORTING_DOCS_DIR=data/supporting_docs
DATABASE_ECHO=false

# CEH API Configuration (Issue #4)
CEH_API_BASE_URL=https://catalogue.ceh.ac.uk
CEH_API_TIMEOUT=30
CEH_API_MAX_RETRIES=3
CEH_API_RETRY_DELAY=1

# HTTP Client Configuration
HTTP_TIMEOUT=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_FACTOR=0.5

# Supporting Documents Configuration (Issue #4)
SUPPORTING_DOCS_CACHE_DIR=./data/supporting_docs
SUPPORTING_DOCS_MAX_FILE_SIZE=104857600
WEB_FOLDER_MAX_DEPTH=3

# Vector Store Configuration (Issue #7)
CHROMA_PATH=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu  # cpu or cuda for GPU
TEXT_CHUNK_SIZE=1000  # Characters per chunk for RAG
TEXT_CHUNK_OVERLAP=200  # Overlap between chunks

# Ollama LLM Configuration (Issue #7)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Distributed Tracing Configuration
# ====================================
# OpenTelemetry (OTLP) for distributed tracing and observability
#
# IMPORTANT: These errors are NORMAL in development environments:
#   "Failed to export traces to localhost:4317, error code: StatusCode.UNAVAILABLE"
#
# This error occurs when JAEGER_ENABLED=true but NO OpenTelemetry Collector
# is running on localhost:4317. To fix:
#
# OPTION 1: Disable tracing (default, recommended for development)
#   JAEGER_ENABLED=false  ← Traces still work locally, no export errors
#
# OPTION 2: Start OpenTelemetry Collector locally
#   docker run --rm -p 4317:4317 otel/opentelemetry-collector:latest
#   Then set: JAEGER_ENABLED=true
#
# OPTION 3: Point to remote collector (staging/production)
#   JAEGER_HOST=your-otel-collector.example.com
#   JAEGER_ENABLED=true
#
# Settings:
JAEGER_HOST=localhost                          # OpenTelemetry Collector host
JAEGER_PORT=6831                               # Jaeger agent port (UDP)
JAEGER_ENABLED=false                           # DISABLE BY DEFAULT (prevent export errors)
JAEGER_SERVICE_NAME=dsh-etl-search-ai          # Service identifier
JAEGER_ENVIRONMENT=development                 # Environment: development|staging|production
JAEGER_SAMPLE_RATE=0.1                         # 10% sampling (reduce for production)
OTEL_EXPORTER_OTLP_TIMEOUT=5                   # Export timeout in seconds (fail fast)

# Metadata Extraction Configuration (Issue #4)
# Alternative: JSON format in .env
METADATA_FORMATS=["iso19139", "json", "schema_org", "rdf"]
EXTRACT_TEXT_FROM_PDFS=true
EXTRACT_TEXT_FROM_DOCX=true

# ETL Configuration
METADATA_IDENTIFIERS_FILE=metadata-file-identifiers.txt
ETL_BATCH_SIZE=10
MAX_CONCURRENT_DOWNLOADS=5

# Environment
ENVIRONMENT=development